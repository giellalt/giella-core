TOOLKITS=
if CAN_HFST
TOOLKITS+=hfst
endif
if CAN_FOMA
TOOLKITS+=foma
endif

AM_TESTS_ENVIRONMENT= export GIELLA_CORE=$(GIELLA_CORE) ; export TOOLKITS=$(TOOLKITS) ;

if WANT_SPELLERS

# ========================================
# Variant testing support
# ========================================

# Initialize variables:
check_SCRIPTS=
CLEANFILES=

# Build lists of variants that need testing:
# - private variants map to $(GTLANG)-x-<variant>.zhfst
# - standardized variants (areas, writing systems) map to $(GTLANG)-<variant>.zhfst
SPELLER_TEST_X_VARIANTS=
SPELLER_TEST_AREA_VARIANTS=
SPELLER_TEST_WSS_VARIANTS=
SPELLER_TEST_STD_VARIANTS=
SPELLER_TEST_VARIANTS=

# Add dialects if defined:
if HAVE_DIALECTS
if WANT_DIALECT_PROOFTOOLS
SPELLER_TEST_X_VARIANTS+=$(DIALECTS)
endif
endif

# Add areas if defined:
if HAVE_AREAS
SPELLER_TEST_AREA_VARIANTS+=$(AREAS)
endif

# Add alternative orthographies if defined:
if HAVE_ALT_ORTHS
if WANT_ALT_ORTH_PROOFTOOLS
SPELLER_TEST_X_VARIANTS+=$(ALT_ORTHS)
endif
endif

# Add alternative writing systems if defined:
if HAVE_ALT_WSS
SPELLER_TEST_WSS_VARIANTS+=$(ALT_WSS)
endif

SPELLER_TEST_STD_VARIANTS+=$(SPELLER_TEST_AREA_VARIANTS) $(SPELLER_TEST_WSS_VARIANTS)

SPELLER_TEST_VARIANTS+=$(SPELLER_TEST_X_VARIANTS) $(SPELLER_TEST_STD_VARIANTS)

# ========================================
# Variant test data generation
# ========================================

# Keep generated test files (don't delete as intermediate files):
.SECONDARY: $(patsubst %,typos-%-generated.tsv,$(SPELLER_TEST_VARIANTS))

# Generate combined test file for default speller:
# always common data, plus default orthography / default writing-system data
# when alternatives are configured.
typos-default-generated.tsv: typos.tsv
	$(AM_V_GEN)cat $< > $@
if HAVE_ALT_ORTHS
	@if test -f "$(srcdir)/typos-$(DEFAULT_ORTH).tsv" ; then \
		cat "$(srcdir)/typos-$(DEFAULT_ORTH).tsv" >> $@ ; \
	fi
endif
if HAVE_ALT_WSS
	@if test -f "$(srcdir)/typos-$(DEFAULT_WS).tsv" ; then \
		cat "$(srcdir)/typos-$(DEFAULT_WS).tsv" >> $@ ; \
	fi
endif

# Generate combined test files for variants that share default-script testdata
# (dialects, areas, alternative orthographies): base + variant-specific.
define variant-typos-combined-rule
typos-$(1)-generated.tsv: typos.tsv typos-$(1).tsv
	$$(AM_V_GEN)cat $$^ > $$@
endef
$(foreach variant,$(SPELLER_TEST_X_VARIANTS) $(SPELLER_TEST_AREA_VARIANTS),$(eval $(call variant-typos-combined-rule,$(variant))))

# Generate variant test files for alternative writing systems:
# do not mix in typos.tsv from the default writing system.
define variant-typos-specific-rule
typos-$(1)-generated.tsv: typos-$(1).tsv
	$$(AM_V_GEN)cat $$< > $$@
endef
$(foreach variant,$(SPELLER_TEST_WSS_VARIANTS),$(eval $(call variant-typos-specific-rule,$(variant))))

# Ensure default test data is generated before default speller quality test.
suggestion-quality.sh: typos-default-generated.tsv

# Explicitly ensure typos-default-generated.tsv is built before check target runs.
# This depends on check-local being available in the including Makefile.am
check-local: typos-default-generated.tsv

# Remove generated test data files on make clean.
CLEANFILES+=$(patsubst %,typos-%-generated.tsv,$(SPELLER_TEST_VARIANTS)) typos-default-generated.tsv
CLEANFILES+=test-speller-variants.sh $(TEST_SPELLER_VARIANT_SCR)

# ========================================
# Variant test execution
# ========================================

# Generate test reports for default speller:
if HAVE_DIALECTS
$(top_srcdir)/docs/typosreport/report.json: typos-default-generated.tsv $(top_builddir)/tools/spellcheckers/$(GTLANG).zhfst
	@echo "*** Testing default speller with combined variant data ***"
	@mkdir -p $(top_srcdir)/docs/typosreport
	$(AM_V_GEN)$(DIVVUNSPELL) accuracy -o $@ \
		$< \
		$(top_builddir)/tools/spellcheckers/$(GTLANG).zhfst
else
if HAVE_AREAS
$(top_srcdir)/docs/typosreport/report.json: typos-default-generated.tsv $(top_builddir)/tools/spellcheckers/$(GTLANG).zhfst
	@echo "*** Testing default speller with combined variant data ***"
	@mkdir -p $(top_srcdir)/docs/typosreport
	$(AM_V_GEN)$(DIVVUNSPELL) accuracy -o $@ \
		$< \
		$(top_builddir)/tools/spellcheckers/$(GTLANG).zhfst
else
if HAVE_ALT_ORTHS
$(top_srcdir)/docs/typosreport/report.json: typos-default-generated.tsv $(top_builddir)/tools/spellcheckers/$(GTLANG).zhfst
	@echo "*** Testing default speller with combined variant data ***"
	@mkdir -p $(top_srcdir)/docs/typosreport
	$(AM_V_GEN)$(DIVVUNSPELL) accuracy -o $@ \
		$< \
		$(top_builddir)/tools/spellcheckers/$(GTLANG).zhfst
endif
endif
endif

# Variant-specific report rules:
define variant-report-rule
$(top_srcdir)/docs/typosreport/report-$(1).json: typos-$(1)-generated.tsv $(top_builddir)/tools/spellcheckers/$(2)$(1).zhfst
	@echo "*** Testing variant speller: $(2)$(1) ***"
	@mkdir -p $(top_srcdir)/docs/typosreport
	$(AM_V_GEN)$(DIVVUNSPELL) accuracy -o $$@ \
		$$< \
		$(top_builddir)/tools/spellcheckers/$(2)$(1).zhfst
endef
$(foreach variant,$(SPELLER_TEST_X_VARIANTS),$(eval $(call variant-report-rule,$(variant),$(GTLANG)-x-)))
$(foreach variant,$(SPELLER_TEST_STD_VARIANTS),$(eval $(call variant-report-rule,$(variant),$(GTLANG)-)))

# Phony target to build all variant reports:
if HAVE_DIALECTS
speller-variant-reports: $(patsubst %,$(top_srcdir)/docs/typosreport/report-%.json,$(SPELLER_TEST_VARIANTS)) $(top_srcdir)/docs/typosreport/report.json
else
if HAVE_AREAS
speller-variant-reports: $(patsubst %,$(top_srcdir)/docs/typosreport/report-%.json,$(SPELLER_TEST_VARIANTS)) $(top_srcdir)/docs/typosreport/report.json
else
if HAVE_ALT_ORTHS
speller-variant-reports: $(patsubst %,$(top_srcdir)/docs/typosreport/report-%.json,$(SPELLER_TEST_VARIANTS)) $(top_srcdir)/docs/typosreport/report.json
else
if HAVE_ALT_WSS
speller-variant-reports: $(patsubst %,$(top_srcdir)/docs/typosreport/report-%.json,$(SPELLER_TEST_VARIANTS)) $(top_srcdir)/docs/typosreport/report.json
else
speller-variant-reports: $(patsubst %,$(top_srcdir)/docs/typosreport/report-%.json,$(SPELLER_TEST_VARIANTS))
endif
endif
endif
endif

TEST_SPELLER_VARIANT_SCR::=$(addsuffix .sh,$(addprefix test-speller-variant-,$(SPELLER_TEST_VARIANTS)))

# ========================================
# Variant test script generation
# ========================================

define test-speller-variants

# Generate a single test runner that tests all variants:
test-speller-variant-$(1).sh: typos-$(1)-generated.tsv $(top_builddir)/tools/spellcheckers/$(2)$(1).zhfst
	$$(AM_V_GEN)( \
	  echo '#!/bin/bash' ; \
	  echo 'if test -f "$$$${GIELLA_CORE}/scripts/termcolors.bash" ; then' ; \
	  echo '    . "$$$${GIELLA_CORE}/scripts/termcolors.bash"' ; \
	  echo 'fi' ; \
	  echo 'TESTER=$(DIVVUNSPELL)' ; \
	  echo 'THRESHOLD=75' ; \
	  echo 'CONFIG="$(srcdir)/../config.json"' ; \
	  echo 'if test x"$$$$TESTER" = x"false" ; then' ; \
	  echo '    printf "%sSKIP%s: missing divvunspell accuracy\\n" "$$$${light_blue}" "$$$${reset}"' ; \
	  echo '    exit 77' ; \
	  echo 'fi' ; \
	  echo 'failed=0' ; \
	  echo 'passed=0' ; \
	  echo 'skipped=0' ; \
	  echo 'TYPOS="$(builddir)/typos-$(1)-generated.tsv"' ; \
	  echo 'ZHFST="$(top_builddir)/tools/spellcheckers/$(2)$(1).zhfst"' ; \
	  echo 'REPORT="$(top_srcdir)/docs/typosreport/report-$(1).json"' ; \
	  echo 'if test ! -f "$$$$ZHFST" ; then' ; \
	  echo '    printf "%sSKIP%s: $(1) (spellchecker not found)\\n" "$$$${light_blue}" "$$$${reset}"' ; \
	  echo '    skipped=$$$$((skipped + 1))' ; \
	  echo '    exit 77' ; \
	  echo 'fi' ; \
	  echo 'if test ! -f "$$$$TYPOS" ; then' ; \
	  echo '    printf "%sSKIP%s: $(1) (test data not found)\\n" "$$$${light_blue}" "$$$${reset}"' ; \
	  echo '    skipped=$$$$((skipped + 1))' ; \
	  echo '    exit 77' ; \
	  echo 'fi' ; \
	  echo 'if test -f "$$$$CONFIG" ; then' ; \
	  echo '    CONFIGOPTION=" -c $$$$CONFIG "' ; \
	  echo 'else' ; \
	  echo '    CONFIGOPTION=""' ; \
	  echo 'fi' ; \
	  echo '"$$$$TESTER" accuracy -T "$$$$THRESHOLD" --verbose $$$$CONFIGOPTION -o "$$$$REPORT" "$$$$TYPOS" "$$$$ZHFST" > /dev/null 2>&1' ; \
	  echo 'rv=$$$$?' ; \
	  echo 'if test $$$$rv = 77 ; then' ; \
	  echo '    printf "%sSKIP%s: $(1)\\n" "$$$${light_blue}" "$$$${reset}"' ; \
	  echo '    skipped=$$$$((skipped + 1))' ; \
	  echo 'elif test $$$$rv -gt 0 ; then' ; \
	  echo '    printf "%sFAIL%s: $(1)\\n" "$$$${red}" "$$$${reset}"' ; \
	  echo '    failed=$$$$((failed + 1))' ; \
	  echo 'else' ; \
	  echo '    printf "%sPASS%s: $(1)\\n" "$$$${green}" "$$$${reset}"' ; \
	  echo '    passed=$$$$((passed + 1))' ; \
	  echo 'fi' ; \
	  echo 'printf "\\nVariant tests: $$$$passed passed, $$$$failed failed, $$$$skipped skipped\\n"' ; \
	  echo 'if test $$$$failed -gt 0 ; then' ; \
	  echo '    exit 1' ; \
	  echo 'elif test $$$$passed -eq 0 && test $$$$skipped -gt 0 ; then' ; \
	  echo '    exit 77' ; \
	  echo 'else' ; \
	  echo '    exit 0' ; \
	  echo 'fi' ; \
	) > $$@
	@chmod +x $$@

endef
$(foreach variant,$(SPELLER_TEST_X_VARIANTS),$(eval $(call test-speller-variants,$(variant),$(GTLANG)-x-)))
$(foreach variant,$(SPELLER_TEST_STD_VARIANTS),$(eval $(call test-speller-variants,$(variant),$(GTLANG)-)))

# Generate a wrapper script that runs all variant tests in sequence:
# This has a fixed name so Automake can track it in TESTS at automake-time.
test-speller-variants.sh: $(TEST_SPELLER_VARIANT_SCR)
	$(AM_V_GEN)( \
	  echo '#!/bin/bash' ; \
	  echo 'if test -f "$${GIELLA_CORE}/scripts/termcolors.bash" ; then' ; \
	  echo '    . "$${GIELLA_CORE}/scripts/termcolors.bash"' ; \
	  echo 'fi' ; \
	  echo 'failed=0 ; passed=0 ; skipped=0' ; \
	  for v in $(SPELLER_TEST_VARIANTS) ; do \
	    echo "if test -x \"$(builddir)/test-speller-variant-$$v.sh\" ; then" ; \
	    echo "    bash \"$(builddir)/test-speller-variant-$$v.sh\"" ; \
	    echo '    rv=$$?' ; \
	    echo '    if test $$rv = 77 ; then skipped=$$((skipped + 1))' ; \
	    echo '    elif test $$rv -gt 0 ; then failed=$$((failed + 1))' ; \
	    echo '    else passed=$$((passed + 1)) ; fi' ; \
	    echo 'fi' ; \
	  done ; \
	  echo 'if test $$failed -gt 0 ; then exit 1' ; \
	  echo 'elif test $$passed -eq 0 && test $$skipped -gt 0 ; then exit 77' ; \
	  echo 'else exit 0 ; fi' ; \
	) > $@
	@chmod +x $@

# Ensure default suggestion-quality prerequisites are built in make check.
check_SCRIPTS+=suggestion-quality.sh

# Add variant test runner if we have variants
if HAVE_DIALECTS
if WANT_DIALECT_PROOFTOOLS
check_SCRIPTS+=test-speller-variants.sh $(TEST_SPELLER_VARIANT_SCR)
OTHER_TEST_RUNNERS+=test-speller-variants.sh
endif # WANT_DIALECT_PROOFTOOLS
else
if HAVE_AREAS
check_SCRIPTS+=test-speller-variants.sh $(TEST_SPELLER_VARIANT_SCR)
OTHER_TEST_RUNNERS+=test-speller-variants.sh
else
if HAVE_ALT_ORTHS
if WANT_ALT_ORTH_PROOFTOOLS
check_SCRIPTS+=test-speller-variants.sh $(TEST_SPELLER_VARIANT_SCR)
OTHER_TEST_RUNNERS+=test-speller-variants.sh
endif
endif
endif
endif

OTHER_TEST_RUNNERS+=test-zhfst-file.sh \
					test-zhfst-basic-sugg-speed.sh \
					suggestion-quality.sh \
					accept-all-lemmas.sh
if CAN_YAML_TEST
YAML_TEST_RUNNERS+=run-desktopspeller-gt-norm-yaml-testcases.sh
endif
endif

.PHONY: speller-variant-reports

TESTS+=$(YAML_TEST_RUNNERS) $(OTHER_TEST_RUNNERS)

